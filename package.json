{
    "name": "obsidian-plugin-toolkit",
    "version": "1.0.0",
    "description": "Monorepo for Obsidian plugins",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "pnpm --filter \"./packages/*\" dev",
        "build": "pnpm --filter \"./packages/*\" build",
        "lint": "pnpm --filter \"./packages/*\" lint",
        "sync": "node scripts/sync-vaults.mjs",
        "prepare": "git config core.hooksPath .githooks || true",
        "dev:file-explorer": "pnpm --filter @obsidian-plugin-toolkit/file-explorer-enhancements dev",
        "dev:copy-path": "pnpm --filter @obsidian-plugin-toolkit/copy-path dev",
        "dev:paste-enhanced": "pnpm --filter @obsidian-plugin-toolkit/paste-enhanced dev",
        "dev:image-zoom": "pnpm --filter @obsidian-plugin-toolkit/image-zoom dev",
        "build:file-explorer": "pnpm --filter @obsidian-plugin-toolkit/file-explorer-enhancements build",
        "build:copy-path": "pnpm --filter @obsidian-plugin-toolkit/copy-path build",
        "build:paste-enhanced": "pnpm --filter @obsidian-plugin-toolkit/paste-enhanced build",
        "build:image-zoom": "pnpm --filter @obsidian-plugin-toolkit/image-zoom build",
        "dev:hide-ui-elements": "pnpm --filter @obsidian-plugin-toolkit/hide-ui-elements dev",
        "build:hide-ui-elements": "pnpm --filter @obsidian-plugin-toolkit/hide-ui-elements build",
        "dev:image-auto-upload-enhanced": "pnpm --filter @obsidian-plugin-toolkit/image-auto-upload-enhanced dev",
        "build:image-auto-upload-enhanced": "pnpm --filter @obsidian-plugin-toolkit/image-auto-upload-enhanced build",
        "dev:mermaid-fit": "pnpm --filter @obsidian-plugin-toolkit/mermaid-fit dev",
        "build:mermaid-fit": "pnpm --filter @obsidian-plugin-toolkit/mermaid-fit build",
        "dev:claudian-enhanced": "pnpm --filter @obsidian-plugin-toolkit/claudian-enhanced dev",
        "build:claudian-enhanced": "pnpm --filter @obsidian-plugin-toolkit/claudian-enhanced build",
        "dev:line-numbers": "pnpm --filter @obsidian-plugin-toolkit/line-numbers dev",
        "build:line-numbers": "pnpm --filter @obsidian-plugin-toolkit/line-numbers build",
        "dev:dev-draggable-settings": "pnpm --filter @obsidian-plugin-toolkit/dev-draggable-settings dev",
        "build:dev-draggable-settings": "pnpm --filter @obsidian-plugin-toolkit/dev-draggable-settings build",
        "dev:auto-link-title-enhanced": "pnpm --filter @obsidian-plugin-toolkit/auto-link-title-enhanced dev",
        "build:auto-link-title-enhanced": "pnpm --filter @obsidian-plugin-toolkit/auto-link-title-enhanced build",
        "dev:blockier-enhanced": "pnpm --filter @obsidian-plugin-toolkit/blockier-enhanced dev",
        "build:blockier-enhanced": "pnpm --filter @obsidian-plugin-toolkit/blockier-enhanced build"
    },
    "keywords": [
        "obsidian",
        "plugins",
        "monorepo"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {},
    "engines": {
        "node": ">=16",
        "pnpm": ">=8"
    }
}