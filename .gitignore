# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
*.js
!*.config.js
!esbuild.config.mjs
!version-bump.mjs

# Package manager locks (keep pnpm-lock.yaml)
package-lock.json
yarn.lock

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Temporary files
*.tmp
*.temp

# Obsidian plugin specific build outputs
**/obsidian-plugin-*/
dist/

# Built plugin folders: packages/<name>/<manifest-id>/ (distDir == manifest id).
# main.js and data.json are already ignored above; also drop the copied
# manifest.json / styles.css so the whole build folder stays untracked. The
# source copies at packages/<name>/ (one level up) are unaffected.
packages/*/*/manifest.json
packages/*/*/styles.css

# Source maps
*.map

# Obsidian plugin data
data.json

# Large example/test files
**/compression-examples/**
**/*compression-examples/**

# Local config (contains personal paths)
.env

